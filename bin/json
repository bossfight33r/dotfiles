#!/usr/bin/env bash
# pretty-print json, optionally filter with jq expression
# usage: echo '{"a":1}' | json
#        echo '{"a":1}' | json .a
if [[ -n "$1" ]]; then
	python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin), indent=2, ensure_ascii=False))" | python3 -c "import sys; [print(l.rstrip()) for l in sys.stdin]"
else
	python3 -m json.tool
fi
