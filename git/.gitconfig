[user]
	name = bossfight33r
	email = bossfighter@proton.me

[core]
	editor = nvim
	pager = delta
	excludesfile = ~/.gitignore_global

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[rebase]
	autoStash = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[delta]
	navigate = true
	light = false
	line-numbers = true
	side-by-side = true
	syntax-theme = kanagawa

[alias]
	st = status
	co = checkout
	br = branch
	lg = log --oneline --graph --decorate --all
	undo = reset HEAD~1 --mixed
	amend = commit --amend --no-edit
	aliases = config --get-regexp alias
